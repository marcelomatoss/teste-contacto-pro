# =============================================================================
# Contact Pro WhatsApp Bot — environment template
# Copy this file to .env and fill the values. NEVER commit .env.
# =============================================================================

# ---------- Backend ----------
PORT=3001
NODE_ENV=development
DATABASE_URL=file:./data/sqlite.db
WHATSAPP_SESSION_PATH=./data/wa-session
MEDIA_PATH=./data/media
CORS_ORIGIN=http://localhost:5173

# Redis used by BullMQ for queue + retries + idempotency
REDIS_URL=redis://localhost:6379

# Auth (JWT). MUST be replaced in production.
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_TTL_HOURS=72

# Initial admin seeded on first boot if no users exist
ADMIN_EMAIL=admin@contactpro.local
ADMIN_PASSWORD=contactpro
DEFAULT_WORKSPACE_NAME=Default Workspace
DEFAULT_WORKSPACE_SLUG=default

# Grafana admin credentials (used by docker-compose)
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# AI providers — two supported setups
# =============================================================================
#
# OPTION A — Anthropic (chat) + OpenAI (audio + RAG embeddings)
#   AI_PROVIDER=anthropic
#   AI_API_KEY=sk-ant-...        # Anthropic
#   STT_API_KEY=sk-...           # OpenAI
#   TTS_API_KEY=sk-...           # OpenAI (same key as STT is fine)
#
# OPTION B — OpenAI for everything (single key)
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4o-mini
#   AI_API_KEY=sk-...            # OpenAI — used as fallback for STT/TTS too
#
# In Option B the backend automatically reuses AI_API_KEY for STT and TTS
# when their dedicated keys are empty, so a single key is enough.
# =============================================================================

# ---------- LLM (chat) ----------
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5-20250929
AI_API_KEY=

# ---------- Speech-to-Text ----------
# Leave STT_API_KEY blank when AI_PROVIDER=openai — AI_API_KEY is reused.
STT_PROVIDER=openai
STT_API_KEY=

# ---------- Text-to-Speech ----------
# Leave TTS_API_KEY blank when AI_PROVIDER=openai — AI_API_KEY is reused.
TTS_PROVIDER=openai
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_API_KEY=

# ---------- Frontend (Vite) ----------
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
